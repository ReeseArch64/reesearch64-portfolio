{
  "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss"],
  "rules": {
    "hue-degree-notation": null,
    "lightness-notation": null,
    "rule-empty-line-before": null,
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "plugin",
          "apply",
          "layer",
          "config",
          "tailwind",
          "reference"
        ]
      }
    ]
  }
}
